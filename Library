-- CREATE TAB

function ZenoXHub:createTab(name)
	if pages[name] then return end

	local btn = Instance.new("TextButton")
	btn.Text = name
	btn.Size = UDim2.new(0,110,1,0)
	btn.BackgroundColor3 = Color3.fromRGB(35,35,35)
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Parent = tabScroll
	Instance.new("UICorner",btn).CornerRadius = UDim.new(0,8)

	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0,Color3.fromRGB(25,25,25)),
		ColorSequenceKeypoint.new(0.7,Color3.fromRGB(80,80,80)),
		ColorSequenceKeypoint.new(1,Color3.fromRGB(170,170,170))
	}
	g.Rotation = 90
	g.Parent = btn

	local page = Instance.new("ScrollingFrame")
	page.Size = UDim2.new(1,0,1,0)
	page.CanvasSize = UDim2.new(0,0,0,0)
	page.ScrollBarThickness = 6
	page.ScrollBarImageColor3 = Color3.fromRGB(200,200,200)
	page.BackgroundTransparency = 1
	page.Visible = false
	page.Parent = holder

	local grid = Instance.new("UIGridLayout")
	grid.CellSize = UDim2.new(0,90,0,90)
	grid.CellPadding = UDim2.new(0,6,0,6)
	grid.Parent = page

	grid:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		page.CanvasSize = UDim2.new(0,0,0,grid.AbsoluteContentSize.Y+10)
	end)

	btn.MouseButton1Click:Connect(function()
		clickSound:Play()

		activeLabel.Visible = false

		for _,p in pairs(pages) do
			p.Visible=false
		end

		page.Visible=true

		TweenService:Create(
			highlight,
			TweenInfo.new(0.25,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
			{Position = btn.Position}
		):Play()
	end)

	pages[name] = page
	tabScroll.CanvasSize = UDim2.new(0, tabLayout.AbsoluteContentSize.X + 20,0,0)
end

