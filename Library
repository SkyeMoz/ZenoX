-- ACTIVE TOGGLES (tracks running scripts + pulse)
local activeToggles = {}

-- stop all active toggles when gui is destroyed
gui.Destroying:Connect(function()
	for name,entry in pairs(activeToggles) do
		if entry and entry.cleanup then
			pcall(entry.cleanup)
		end
		activeToggles[name] = nil
	end
end)

-- helper functions to start/stop a toggle for a slot
local function startToggleForSlot(data, slot, outline)
	if activeToggles[data.Name] then return end

	local ok, ret = pcall(function()
		local s = game:HttpGet(data.Script)
		local f, loadErr = loadstring(s)
		if not f then error(loadErr) end
		return f()
	end)

	if not ok then
		warn("[ZenoX] Error executing toggle script for "..tostring(data.Name)..": "..tostring(ret))
		-- don't enable visuals if error
		return
	end

	-- detect cleanup function or methods
	local cleanup
	if type(ret) == "function" then
		cleanup = ret
	elseif type(ret) == "table" then
		if type(ret.Stop) == "function" then
			cleanup = ret.Stop
		elseif type(ret.cleanup) == "function" then
			cleanup = ret.cleanup
		elseif type(ret.disconnect) == "function" then
			cleanup = ret.disconnect
		end
	end

	activeToggles[data.Name] = { cleanup = cleanup, pulsing = true }

	-- visual enable: whole-slot outline (white)
	outline.Color = Color3.new(1,1,1)
	outline.Enabled = true

	-- simple pulsing outline (tween thickness)
	outline.Thickness = 3
	task.spawn(function()
		while activeToggles[data.Name] and activeToggles[data.Name].pulsing do
			local t1 = TweenService:Create(outline, TweenInfo.new(0.45, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Thickness = 6})
			t1:Play()
			task.wait(0.45)
			local t2 = TweenService:Create(outline, TweenInfo.new(0.45, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Thickness = 3})
			t2:Play()
			task.wait(0.45)
		end
		-- ensure thickness resets when pulsing stops
		if outline and outline.Parent then
			outline.Thickness = 3
		end
	end)
end

local function stopToggleForSlot(data, slot, outline)
	local entry = activeToggles[data.Name]
	if not entry then return end
	entry.pulsing = false
	if entry.cleanup then
		pcall(entry.cleanup)
	end
	activeToggles[data.Name] = nil
	-- visual disable
	if outline then
		outline.Enabled = false
	end
end

