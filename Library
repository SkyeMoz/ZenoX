--------------------------------------------------
-- CREATE SLOT
--------------------------------------------------
function ZenoXHub:createSlot(data)
	if not pages[data.Tab] then self:createTab(data.Tab) end

	local function buildSlot(parent)
		local slot = Instance.new("TextButton")
		slot.Size = UDim2.new(0,90,0,90)
		slot.BackgroundColor3 = Color3.fromRGB(40,40,40)
		slot.Text = ""
		slot.Name = data.Name
		slot.Parent = parent
		Instance.new("UICorner", slot).CornerRadius = UDim.new(0,8)

		local sg = Instance.new("UIGradient")
		sg.Color = ColorSequence.new{
			ColorSequenceKeypoint.new(0,Color3.fromRGB(25,25,25)),
			ColorSequenceKeypoint.new(0.7,Color3.fromRGB(90,90,90)),
			ColorSequenceKeypoint.new(1,Color3.fromRGB(180,180,180))
		}
		sg.Rotation = 90
		sg.Parent = slot

		local icon = Instance.new("ImageLabel")
		icon.Size = UDim2.new(0,60,0,60)
		icon.Position = UDim2.new(0.5,-30,0,5)
		icon.BackgroundTransparency = 1
		-- allow Icon to be either rbxassetid number or plain number
		if type(data.Icon) == "number" or tostring(data.Icon):match("^%d+$") then
			icon.Image = "rbxassetid://"..tostring(data.Icon)
		else
			-- if not a numeric id, try to use string directly (or a fallback)
			pcall(function() icon.Image = tostring(data.Icon) end)
		end
		icon.Parent = slot

		local text = Instance.new("TextLabel")
		text.Size = UDim2.new(1,0,0,20)
		text.Position = UDim2.new(0,0,1,-20)
		text.BackgroundTransparency = 1
		text.Text = data.Name
		text.TextColor3 = Color3.new(1,1,1)
		text.Font = Enum.Font.Gotham
		text.TextSize = 14
		text.Parent = slot

		-- favorite star
		local star = Instance.new("TextButton")
		star.Name = "FavStar"
		star.Text = favorites[data.Name] and "★" or "☆"
		star.Size = UDim2.new(0,18,0,18)
		star.Position = UDim2.new(1,-20,0,2)
		star.BackgroundTransparency = 1
		star.TextColor3 = favorites[data.Name] and Color3.fromRGB(255,221,0) or Color3.fromRGB(150,150,150)
		star.Parent = slot
		star.ZIndex = 11 -- make sure star receives clicks over outline

		-- outline stroke (whole-slot)
		local outline = Instance.new("UIStroke")
		outline.Thickness = 3
		outline.Color = Color3.fromRGB(255,170,0)
		outline.Transparency = 0
		outline.Parent = slot
		outline.Enabled = false
		outline.ZIndex = 10

		-- make sure slot ZIndex is below stroke so stroke shows
		slot.ZIndex = 9

		-- click behavior
		slot.MouseButton1Click:Connect(function()
			clickSound:Play()
			-- Toggle logic: whole card toggles
			if data.Logic == "Toggle" then
				if not activeToggles[data.Name] then
					startToggleForSlot(data, slot, outline)
				else
					stopToggleForSlot(data, slot, outline)
				end
				return
			end

			-- Non-toggle actions
			if data.Logic == "Execute" then
				-- fetch content then run
				local content, err = fetchScriptContent(data.Script)
				if not content then
					warn("[ZenoX] Execute fetch failed:", err)
					return
				end
				local f, loadErr = loadstring(content)
				if not f then
					warn("[ZenoX] Execute loadstring error:", loadErr)
					return
				end
				pcall(f)
			elseif data.Logic == "Copy" then
				pcall(function() setclipboard(data.Script) end)
			end
		end)

		-- favorite star behavior
		star.MouseButton1Click:Connect(function()
			clickSound:Play()
			favorites[data.Name] = not favorites[data.Name]
			saveFavorites()

			-- update all stars for this slot across pages
			for _, p in pairs(pages) do
				for _, slotChild in pairs(p:GetChildren()) do
					if slotChild:IsA("TextButton") and slotChild.Name == data.Name then
						local s = slotChild:FindFirstChild("FavStar")
						if s then
							s.Text = favorites[data.Name] and "★" or "☆"
							s.TextColor3 = favorites[data.Name] and Color3.fromRGB(255,221,0) or Color3.fromRGB(150,150,150)
						end
					end
				end
			end

			-- remove old favorite entry in Favorites tab
			for _, v in pairs(pages["Favorites ⭐"]:GetChildren()) do
				if v:IsA("TextButton") and v.Name == data.Name then
					v:Destroy()
				end
			end

			-- add new favorite in Favorites tab
			if favorites[data.Name] then
				buildSlot(pages["Favorites ⭐"])
			end
		end)

		-- show outline if active already
		if activeToggles[data.Name] then
			outline.Color = Color3.new(1,1,1)
			outline.Enabled = true
		end
	end -- buildSlot

	-- add to favorites tab if necessary (buildSlot available here)
	if favorites[data.Name] then
		buildSlot(pages["Favorites ⭐"])
	end

	table.insert(allSlots, data)
	buildSlot(pages[data.Tab])
end

