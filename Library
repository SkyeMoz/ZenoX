local activeToggles = {} -- [name] = { cleanup = fn or nil, pulsing = bool }

-- helper: fetch script content (URL or inline)
local function fetchScriptContent(scriptField)
	if type(scriptField) ~= "string" then return nil, "script not a string" end
	local trimmed = scriptField:match("^%s*(.-)%s*$") or scriptField
	if trimmed:match("^https?://") then
		local ok, res = pcall(function() return game:HttpGet(trimmed) end)
		if not ok then return nil, res end
		return res
	else
		-- treat as inline code
		return trimmed
	end
end

-- stop all active toggles when gui is destroyed
gui.Destroying:Connect(function()
	for name,entry in pairs(activeToggles) do
		if entry and entry.cleanup then
			pcall(entry.cleanup)
		end
		activeToggles[name] = nil
	end
end)

--------------------------------------------------
-- START / STOP TOGGLE HELPERS
--------------------------------------------------
local function startToggleForSlot(data, slot, outline)
	if activeToggles[data.Name] then return end

	-- fetch script (url or inline)
	local content, fetchErr = fetchScriptContent(data.Script)
	if not content then
		warn("[ZenoX] failed to fetch script for "..tostring(data.Name)..": "..tostring(fetchErr))
		return
	end

	local f, loadErr = loadstring(content)
	if not f then
		warn("[ZenoX] loadstring error for "..tostring(data.Name)..": "..tostring(loadErr))
		return
	end

	local ok, ret = pcall(f)
	if not ok then
		warn("[ZenoX] error executing toggle script for "..tostring(data.Name)..": "..tostring(ret))
		return
	end

	-- find cleanup
	local cleanup
	if type(ret) == "function" then
		cleanup = ret
	elseif type(ret) == "table" then
		if type(ret.Stop) == "function" then
			cleanup = ret.Stop
		elseif type(ret.cleanup) == "function" then
			cleanup = ret.cleanup
		elseif type(ret.disconnect) == "function" then
			cleanup = ret.disconnect
		end
	end

	activeToggles[data.Name] = { cleanup = cleanup, pulsing = true }

	-- enable outline (white) and pulse
	if outline then
		outline.Color = Color3.new(1,1,1)
		outline.Enabled = true
		outline.ZIndex = 10
		outline.Thickness = 3

		task.spawn(function()
			while activeToggles[data.Name] and activeToggles[data.Name].pulsing do
				if outline and outline.Parent then
					local t1 = TweenService:Create(outline, TweenInfo.new(0.45, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Thickness = 6})
					t1:Play()
					task.wait(0.45)
					local t2 = TweenService:Create(outline, TweenInfo.new(0.45, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Thickness = 3})
					t2:Play()
					task.wait(0.45)
				else
					break
				end
			end
			-- reset
			if outline and outline.Parent then
				outline.Thickness = 3
			end
		end)
	end

	print("[ZenoX] Toggle started:", data.Name, "cleanup:", tostring(cleanup ~= nil))
end

local function stopToggleForSlot(data, slot, outline)
	local entry = activeToggles[data.Name]
	if not entry then return end
	entry.pulsing = false
	if entry.cleanup then
		pcall(entry.cleanup)
	end
	activeToggles[data.Name] = nil

	-- visual disable
	if outline then
		outline.Enabled = false
	end

	print("[ZenoX] Toggle stopped:", data.Name)
end

